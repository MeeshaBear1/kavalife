# ---------------------------------------------------------------------------
# Kava Life — environment configuration
# Copy to .env and fill in. Docker Compose supplies safe defaults for local dev.
# ---------------------------------------------------------------------------

# Postgres connection string (POOLED — the app runtime uses this).
# For local `npm run dev` against the Compose DB (mapped to host port 5434):
DATABASE_URL="postgresql://kava:kava_dev_password@localhost:5434/kavalife"
# Inside Docker Compose the app uses: postgresql://kava:kava_dev_password@db:5432/kavalife
#
# DIRECT (non-pooled) connection — used by the Prisma CLI for `db push`/migrate.
# Locally/Docker this is the same as DATABASE_URL. On Vercel Postgres, set
# DATABASE_URL=$POSTGRES_PRISMA_URL (pooled) and DIRECT_URL=$POSTGRES_URL_NON_POOLING.
DIRECT_URL="postgresql://kava:kava_dev_password@localhost:5434/kavalife"

# Public site URL (used for payment redirect URLs, canonical links, webhook URL).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Where admin-uploaded product photos are stored. In Docker this is a mounted
# volume (/app/uploads); locally it defaults to ./uploads if unset.
# UPLOAD_DIR="./uploads"
#
# On Vercel, the filesystem is ephemeral — set a Vercel Blob token instead and
# uploads are stored there automatically (create a Blob store in the dashboard).
# BLOB_READ_WRITE_TOKEN=""

# Admin session signing secret. MUST be >= 32 chars. Generate a random one for prod:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET="dev_change_me_session_secret_min_32_chars_long_please"

# Seed/bootstrap admin account (created on first `db:seed` if it doesn't exist).
ADMIN_EMAIL="admin@kavalife.local"
ADMIN_PASSWORD="changeme123"

# ===========================================================================
# Payments. Processor priority: Square (if set) -> Stripe (if set) -> mock.
# Leave ALL blank to run MOCK CHECKOUT mode (orders marked paid without a real
# charge) — great for local dev/demos. Mock mode is BLOCKED in production
# (NODE_ENV=production) unless you set ALLOW_MOCK_CHECKOUT=1, so the live store
# can never hand out free product.
# ===========================================================================

# ---- Square (PRIMARY) ------------------------------------------------------
# Production credentials from the Square Developer dashboard.
SQUARE_ACCESS_TOKEN=""
SQUARE_LOCATION_ID=""
# "production" (default) or "sandbox" for test credentials.
SQUARE_ENV="production"
# Signature key for the webhook subscription (Developer > Webhooks).
SQUARE_WEBHOOK_SIGNATURE_KEY=""
# Optional: override the webhook URL Square signs against (defaults to
# NEXT_PUBLIC_SITE_URL + /api/webhooks/square). Optional: SQUARE_API_VERSION.
# SQUARE_WEBHOOK_URL=""

# ---- Stripe (FALLBACK) -----------------------------------------------------
# Used only when Square is NOT configured.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Set to "1" to explicitly allow mock checkout in production (staging only).
# ALLOW_MOCK_CHECKOUT=""
