# ---------------------------------------------------------------------------
# Kava Life — environment configuration
# Copy to .env and fill in. Docker Compose supplies safe defaults for local dev.
# ---------------------------------------------------------------------------

# Postgres connection string.
# For local `npm run dev` against the Compose DB (mapped to host port 5434):
DATABASE_URL="postgresql://kava:kava_dev_password@localhost:5434/kavalife"
# Inside Docker Compose the app uses: postgresql://kava:kava_dev_password@db:5432/kavalife

# Public site URL (used for Stripe redirect URLs, canonical links).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Where admin-uploaded product photos are stored. In Docker this is a mounted
# volume (/app/uploads); locally it defaults to ./uploads if unset.
# UPLOAD_DIR="./uploads"

# Admin session signing secret. MUST be >= 32 chars. Generate a random one for prod:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET="dev_change_me_session_secret_min_32_chars_long_please"

# Seed/bootstrap admin account (created on first `db:seed` if it doesn't exist).
ADMIN_EMAIL="admin@kavalife.local"
ADMIN_PASSWORD="changeme123"

# ---- Stripe (optional) -----------------------------------------------------
# Leave BLANK to run the store in MOCK CHECKOUT mode (orders are created and
# marked paid without a real charge — perfect for local dev & demos).
# Fill these in to enable real Stripe Checkout.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
