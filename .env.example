# ---------------------------------------------------------------------------
# Kava Life — environment configuration
# Copy to .env and fill in. Docker Compose supplies safe defaults for local dev.
# ---------------------------------------------------------------------------

# Postgres connection string.
#
# DEFAULT below is for `npm run db:dev` — a zero-Docker local Postgres (PGlite).
# The extra query params are required for that WASM server:
#   sslmode=disable    (it speaks plaintext)
#   pgbouncer=true     (one backend behind a multiplexer; no named prepared stmts)
#   connection_limit=1
DATABASE_URL="postgresql://kava:kava_dev_password@127.0.0.1:5434/kavalife?sslmode=disable&pgbouncer=true&connection_limit=1"
#
# For Docker Compose Postgres (host) OR any managed Postgres (Supabase/Railway/RDS),
# use a PLAIN url with NO PGlite params (and SSL as your provider requires):
#   DATABASE_URL="postgresql://kava:kava_dev_password@localhost:5434/kavalife"
# Inside Docker Compose the app uses: postgresql://kava:kava_dev_password@db:5432/kavalife

# Public site URL (used for Square redirect URLs, canonical links).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Where admin-uploaded product photos are stored. In Docker this is a mounted
# volume (/app/uploads); locally it defaults to ./uploads if unset.
# UPLOAD_DIR="./uploads"

# Admin session signing secret. MUST be >= 32 chars. Generate a random one for prod:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET="dev_change_me_session_secret_min_32_chars_long_please"

# Seed/bootstrap admin account (created on first `db:seed` if it doesn't exist).
ADMIN_EMAIL="admin@kavalife.local"
ADMIN_PASSWORD="changeme123"

# ---- Checkout mode ---------------------------------------------------------
# Controls what happens when a customer checks out:
#   "auto"    (default) real Square if creds are set below, else mock.
#   "reserve" record the order + contact info but DON'T charge — you collect
#             payment manually from Admin → Orders. Use this to launch before a
#             kava-friendly card processor is approved (mainstream processors
#             like Square/Stripe classify kava as high-risk). See SQUARE_SETUP.md.
#   "mock"    always mark orders paid instantly, no charge (dev/demo).
#   "square"  force real Square (needs the credentials below).
#CHECKOUT_MODE="auto"

# ---- Square (optional) -----------------------------------------------------
# Leave SQUARE_ACCESS_TOKEN / SQUARE_LOCATION_ID BLANK to run the store in MOCK
# CHECKOUT mode (orders are created and marked paid without a real charge —
# perfect for local dev & demos). Fill them in for real Square Checkout.
# Full walkthrough: see SQUARE_SETUP.md
#
# "sandbox" = Square test environment; "production" = take real money.
SQUARE_ENVIRONMENT="sandbox"
# From Square Dashboard → Developer → your app → Credentials (match the env above).
SQUARE_ACCESS_TOKEN=""
# Square Dashboard → Developer → Locations (the ID of the location to sell from).
SQUARE_LOCATION_ID=""
# Square Dashboard → Developer → Webhooks → your subscription → Signature key.
SQUARE_WEBHOOK_SIGNATURE_KEY=""
# Optional: the EXACT webhook URL configured in Square. Defaults to
# ${NEXT_PUBLIC_SITE_URL}/api/webhooks/square. Override when your public URL
# differs (e.g. an ngrok tunnel during local webhook testing).
#SQUARE_WEBHOOK_URL=""
# Optional: override the pinned Square API version if Square rejects the default.
#SQUARE_API_VERSION="2025-01-23"
