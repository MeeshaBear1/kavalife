# ---------------------------------------------------------------------------
# Kava Life — PRODUCTION environment (Docker Compose)
#
# On your server:  cp .env.production.example .env   then fill in the values.
# Compose reads ".env" automatically. NEVER commit the filled-in .env.
# Bring the stack up with:
#   docker compose --profile prod up -d --build
# ---------------------------------------------------------------------------

# --- Your domain --------------------------------------------------------------
# The bare hostname Caddy serves + gets a TLS cert for (NO https://, no path).
# Point this domain's DNS A record at this server BEFORE starting Caddy.
SITE_DOMAIN="shop.yourkavadomain.com"
# The full public URL (WITH https://). Used for canonical links + any redirects.
NEXT_PUBLIC_SITE_URL="https://shop.yourkavadomain.com"

# --- Checkout mode ------------------------------------------------------------
# "reserve" = take orders WITHOUT charging; you collect payment manually from
# Admin → Orders. This is the launch mode until a kava-friendly card processor
# is connected (mainstream processors like Square/Stripe classify kava as
# high-risk). Switch to "square" once a processor is live (see SQUARE_SETUP.md).
CHECKOUT_MODE="reserve"

# --- Database password --------------------------------------------------------
# Compose injects this into BOTH the Postgres container and the app's
# DATABASE_URL. Generate a strong one:
#   openssl rand -base64 24
POSTGRES_PASSWORD="CHANGE_ME_strong_db_password"

# --- Database URLs (Docker Compose sets these automatically from POSTGRES_PASSWORD)
# For Docker: leave blank — docker-compose.yml builds these from POSTGRES_PASSWORD.
# For Vercel + Neon: DATABASE_URL = pooled URL; DIRECT_URL = direct (non-pooled) URL.
# Both are provided when you add a Neon database in the Vercel dashboard.
DATABASE_URL=""
DIRECT_URL=""

# --- Admin login --------------------------------------------------------------
# Created on first boot (idempotent seed). Use a real email + strong password.
ADMIN_EMAIL="you@yourkavadomain.com"
ADMIN_PASSWORD="CHANGE_ME_strong_admin_password"

# --- Session signing secret (>= 32 chars) -------------------------------------
# Generate:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
#   (or)     openssl rand -hex 48
SESSION_SECRET="CHANGE_ME_generate_a_64+_char_random_hex_string"

# --- Square (leave blank while in reserve mode) -------------------------------
# Fill these only when you switch CHECKOUT_MODE to "square". See SQUARE_SETUP.md.
SQUARE_ENVIRONMENT="production"
SQUARE_ACCESS_TOKEN=""
SQUARE_LOCATION_ID=""
SQUARE_WEBHOOK_SIGNATURE_KEY=""
#SQUARE_WEBHOOK_URL=""
#SQUARE_API_VERSION="2025-01-23"
